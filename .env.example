# Environment example for portal
DJANGO_SECRET_KEY=change-me-to-a-long-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=sqlite:///db.sqlite3
GRAFANA_BASE_URL=https://grafana.example.com/d/your-dashboard

# InfluxDB Settings (Telemetria)
INFLUXDB_HOST=127.0.0.1
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=iot_telemetry
INFLUXDB_USER=your_influx_user
INFLUXDB_PASSWORD=your_influx_password
